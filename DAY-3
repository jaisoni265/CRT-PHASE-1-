// 📝 Task: Repeatedly ask for PIN until correct
// ==============================================

#include <iostream>
using namespace std;

int main() {
    int password;
    
    do{
        cout << "Enter your password here...";
        cin >> password;
    } while(password != 1234);
    
    cout << "Phone Unlocked...";
}

