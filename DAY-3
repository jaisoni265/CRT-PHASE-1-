//problem 5
// Print 1 to 10 using do-whie loop

#include <iostream>
using namespace std;

int main() {
    int i = 1;
    do {
        cout << i << "";
        i++;
    } while (i <= 10);
}


//problem 6 
// Factorial of a numbers
#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    int fact =1;
    
    for(int i = n; i >=1; i--) {
        fact = fact * i;
    }
    cout << fact;
}


